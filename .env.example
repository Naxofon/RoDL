# ClickHouse — app user (data tables)
CLICKHOUSE_USER=default_user
CLICKHOUSE_PASSWORD=change_me

# ClickHouse — access user (Accesses table only)
CLICKHOUSE_ACCESS_USER=access_user
CLICKHOUSE_ACCESS_PASSWORD=change_me

# ClickHouse — admin user (container init & healthcheck)
CLICKHOUSE_ADMIN_PASSWORD=change_me

# ClickHouse connection
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123

# Note: database names are configured in config/loaders.yaml

# Prefect internal DB (PostgreSQL)
PREFECT_DB_USER=prefect
PREFECT_DB_PASSWORD=prefect
PREFECT_DB_NAME=prefect

# Timezone (affects pipeline scheduling)
TZ=Asia/Novosibirsk

# Prefect API (for host-side CLI / UI access)
PREFECT_API_URL=http://localhost:4200/api

# Telegram admin bot
ADMIN_BOT_TOKEN=put_telegram_bot_token_here
ADMIN_REGISTRATION_CODE=your_secure_registration_code_here