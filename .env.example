# Data user (tables in loader_direct, loader_metrika)
CLICKHOUSE_USER=default_user
CLICKHOUSE_PASSWORD=change_me

# Access-only user (only loader.Accesses)
CLICKHOUSE_ACCESS_USER=access_user
CLICKHOUSE_ACCESS_PASSWORD=change_me

# ClickHouse connection
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123

# Note: Database names are configured in config/loaders.yaml

## Timezone (for correct pipeline scheduling)
TZ=Asia/Novosibirsk

## Prefect API (for host CLI/UI access)
PREFECT_API_URL=http://localhost:4200/api

## Telegram admin bot (all tokens are now managed via admin bot)
ADMIN_BOT_TOKEN=put_telegram_bot_token_here
ADMIN_REGISTRATION_CODE="your_secure_registration_code_here"

## Prefect (optional overrides)
# PREFECT_API_URL=http://prefect-server:4200/api
# PREFECT_LOGGING_LEVEL=INFO